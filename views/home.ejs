<!DOCTYPE html>
<html>
<head>
    <title>BirdSky · elegant landing</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(180deg, #b7dff7 0%, #c6e9ff 40%, #d4f0ff 70%, #b3d5e7 100%);
            font-family: 'Segoe UI', 'Roboto', system-ui, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow-x: hidden;
        }

        /* birds flying – smooth across-screen animation */
        .bird {
            position: absolute;
            color: #2c4e5e;
            font-size: 2.2rem;
            opacity: 0.35;
            z-index: 1;
            pointer-events: none;
            filter: drop-shadow(0 2px 6px rgba(0,0,0,0.08));
            white-space: nowrap;
        }

        @keyframes flyAcross {
            0% { transform: translate(-120px, 0) rotate(-5deg); opacity: 0.35; }
            15% { transform: translate(15vw, -20px) rotate(2deg) scale(1.1); opacity: 0.5; }
            30% { transform: translate(35vw, 10px) rotate(-3deg); opacity: 0.4; }
            50% { transform: translate(55vw, -15px) rotate(4deg) scale(1); opacity: 0.45; }
            70% { transform: translate(75vw, 5px) rotate(-2deg); opacity: 0.4; }
            85% { transform: translate(95vw, -10px) rotate(3deg); opacity: 0.35; }
            100% { transform: translate(120vw, 0) rotate(-5deg); opacity: 0.35; }
        }

        @keyframes flyAcrossReverse {
            0% { transform: translate(120vw, 0) scaleX(-1) rotate(5deg); opacity: 0.35; }
            15% { transform: translate(85vw, -15px) scaleX(-1) rotate(-2deg); opacity: 0.45; }
            50% { transform: translate(45vw, 12px) scaleX(-1) rotate(3deg); opacity: 0.5; }
            85% { transform: translate(5vw, -8px) scaleX(-1) rotate(-4deg); opacity: 0.4; }
            100% { transform: translate(-120px, 0) scaleX(-1) rotate(5deg); opacity: 0.35; }
        }

        @keyframes birdBob {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }

        .bird1 { top: 12%; left: 0; animation: flyAcross 18s infinite ease-in-out; font-size: 2rem; }
        .bird2 { top: 28%; right: 0; animation: flyAcrossReverse 22s infinite ease-in-out 2s; font-size: 1.8rem; }
        .bird3 { top: 55%; left: 0; animation: flyAcross 25s infinite ease-in-out 4s; font-size: 2.2rem; }
        .bird4 { bottom: 25%; right: 0; animation: flyAcrossReverse 20s infinite ease-in-out 1s; font-size: 1.9rem; }
        .bird5 { top: 42%; left: 0; animation: flyAcross 28s infinite ease-in-out 3s; font-size: 1.7rem; }

        /* box with bird sitting – top left corner */
        .bird-perch-box {
            position: absolute;
            top: 20px;
            left: 20px;
            z-index: 15;
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(8px);
            border-radius: 16px;
            padding: 12px 18px 8px;
            box-shadow: 0 8px 24px rgba(0, 40, 40, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.8);
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .bird-perch-box .perch-bird {
            font-size: 2rem;
            margin-bottom: 2px;
            animation: birdBob 2.5s infinite ease-in-out;
        }

        .bird-perch-box .perch-label {
            font-size: 0.7rem;
            color: #2c4e5e;
            opacity: 0.7;
            font-weight: 500;
            letter-spacing: 1px;
        }

        /* clouds – soft background elements */
        .cloud {
            position: absolute;
            background: rgba(255, 255, 255, 0.5);
            border-radius: 120px;
            filter: blur(40px);
            z-index: 0;
            pointer-events: none;
        }

        .cloud1 {
            width: 500px;
            height: 120px;
            top: 5%;
            right: -100px;
            background: rgba(255, 255, 255, 0.5);
        }

        .cloud2 {
            width: 600px;
            height: 150px;
            bottom: 10%;
            left: -150px;
            background: rgba(240, 250, 255, 0.6);
        }

        .cloud3 {
            width: 350px;
            height: 90px;
            top: 40%;
            left: 15%;
            background: rgba(255, 255, 255, 0.4);
        }

        /* main card – clean and elegant */
        .card {
            position: relative;
            z-index: 20;
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-radius: 60px;
            padding: 50px 70px;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.7);
            box-shadow: 0 30px 50px -20px rgba(0, 40, 40, 0.3);
            max-width: 700px;
            width: 90%;
        }

        /* welcome text */
        .welcome-text {
            font-family: 'Times New Roman', Times, serif;
            font-size: 2.5rem;
            color: #000000;
            margin-bottom: 20px;
            font-weight: 500;
            letter-spacing: 1px;
        }

        /* logo container – centered with background */
        .logo-container {
            margin-bottom: 20px;
            display: flex;
            justify-content: center;
            background: rgba(255, 255, 255, 0.6);
            padding: 22px 28px;
            border-radius: 24px;
            box-shadow: 0 4px 20px rgba(0, 30, 30, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.8);
        }

        .logo-container img {
            width: 130px;
            height: auto;
            filter: drop-shadow(0 8px 12px rgba(0, 30, 30, 0.2));
            display: block;
            background: transparent;
        }

        /* BirdSky title – pink shades */
        .birdsky-title {
            font-family: 'Times New Roman', Times, serif;
            font-size: 4.8rem;
            font-weight: 600;
            margin-bottom: 20px;
            letter-spacing: -0.5px;
        }

        .pink-letter {
            display: inline-block;
            animation: gentleFloat 3s infinite ease-in-out;
        }

        @keyframes gentleFloat {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-4px); }
        }

        /* pink gradient shades */
        .pink1 { color: #fba0b3; }
        .pink2 { color: #fa8eaa; }
        .pink3 { color: #f97b9f; }
        .pink4 { color: #f86994; }
        .pink5 { color: #f75689; }
        .pink6 { color: #f6447d; }
        .pink7 { color: #f53172; }

        /* instruction text */
        .instruction {
            font-size: 1.4rem;
            color: #1d4a4a;
            margin-bottom: 35px;
            font-weight: 400;
            background: rgba(255, 255, 255, 0.25);
            display: inline-block;
            padding: 10px 40px;
            border-radius: 50px;
            backdrop-filter: blur(4px);
            border: 1px solid rgba(255, 255, 255, 0.5);
        }

        /* button group – clean layout */
        .button-group {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-top: 5px;
        }

        button {
            font-size: 1.9rem;
            padding: 14px 48px;
            border: none;
            border-radius: 50px;
            color: white;
            font-weight: 500;
            cursor: pointer;
            box-shadow: 0 12px 22px -8px rgba(0, 40, 40, 0.3);
            transition: all 0.2s ease;
            min-width: 170px;
            font-family: 'Segoe UI', system-ui, sans-serif;
            border: 1px solid rgba(255, 255, 255, 0.4);
            letter-spacing: 0.5px;
        }

        .login-btn {
            background: linear-gradient(135deg, #2b7a5c, #1d5e45);
        }

        .login-btn:hover {
            background: linear-gradient(135deg, #328f6a, #23754f);
            box-shadow: 0 16px 28px -8px rgba(30, 90, 70, 0.5);
            transform: translateY(-2px);
        }

        .register-btn {
            background: linear-gradient(135deg, #1f7a8f, #135e70);
        }

        .register-btn:hover {
            background: linear-gradient(135deg, #2790a8, #196f85);
            box-shadow: 0 16px 28px -8px rgba(20, 90, 110, 0.5);
            transform: translateY(-2px);
        }

        a {
            text-decoration: none;
        }

        /* subtle decorative birds near card */
        .decor-bird {
            position: absolute;
            font-size: 1.4rem;
            opacity: 0.25;
            color: #1f5a5a;
            pointer-events: none;
            z-index: 15;
        }

        .decor1 { top: -20px; right: 20px; }
        .decor2 { bottom: -20px; left: 30px; }

        @media (max-width: 650px) {
            .card { padding: 35px 25px; }
            .welcome-text { font-size: 2rem; }
            .birdsky-title { font-size: 3.8rem; }
            .instruction { font-size: 1.2rem; padding: 8px 25px; }
            button { font-size: 1.6rem; padding: 12px 32px; min-width: 140px; }
            .button-group { gap: 20px; }
            .logo-container img { width: 110px; }
            .logo-container { padding: 16px 20px; }
            .bird-perch-box { top: 12px; left: 12px; padding: 10px 14px 6px; }
            .bird-perch-box .perch-bird { font-size: 1.6rem; }
        }
    </style>
</head>
<body>

    <!-- box with bird sitting – top left -->
    <div class="bird-perch-box">
        <span class="perch-bird">🕊️</span>
        <span class="perch-label">BirdSky</span>
    </div>

    <!-- soft clouds -->
    <div class="cloud cloud1"></div>
    <div class="cloud cloud2"></div>
    <div class="cloud cloud3"></div>

    <!-- flying birds background -->
    <div class="bird bird1">🕊️</div>
    <div class="bird bird2">🕊️</div>
    <div class="bird bird3">🕊️</div>
    <div class="bird bird4">🕊️</div>
    <div class="bird bird5">🕊️</div>

    <!-- main card -->
    <div class="card">
        <!-- Welcome to (black) -->
        <div class="welcome-text">Welcome to</div>
        
        <!-- logo in the middle between Welcome to and BirdSky -->
        <div class="logo-container">
            <img src="/images/birdSky3.0.png" alt="BirdSky Logo">
        </div>
        
        <!-- BirdSky in pink shades -->
        <div class="birdsky-title">
            <span class="pink-letter pink1">B</span>
            <span class="pink-letter pink2">i</span>
            <span class="pink-letter pink3">r</span>
            <span class="pink-letter pink4">d</span>
            <span class="pink-letter pink5">S</span>
            <span class="pink-letter pink6">k</span>
            <span class="pink-letter pink7">y</span>
        </div>
        
        <!-- instruction text -->
        <div class="instruction">Please login or create an account</div>

        <!-- buttons – clean UI, no birds on buttons -->
        <div class="button-group">
            <a href="/login">
                <button class="login-btn">Login</button>
            </a>
            <a href="/register">
                <button class="register-btn">Register</button>
            </a>
        </div>

        <!-- tiny decorative birds near card (very subtle) -->
        <div class="decor-bird decor1">🕊️</div>
        <div class="decor-bird decor2">🕊️</div>
    </div>

    <!-- one extra faint bird far away -->
    <div style="position: absolute; top: 10%; right: 8%; font-size: 1.8rem; opacity: 0.1; transform: rotate(5deg);">🕊️</div>

</body>
</html>