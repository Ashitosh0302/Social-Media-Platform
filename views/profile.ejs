<!DOCTYPE html>
<html>
<head>
    <title>Profile</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f5f5f5;
        }

        .container {
            max-width: 900px;
            margin: 40px auto;
            background: #ffffff;
            padding: 30px;
            border-radius: 8px;
        }

        .profile-header {
            display: flex;
            align-items: center;
            gap: 30px;
            border-bottom: 1px solid #ddd;
            padding-bottom: 20px;
        }

        .profile-header img {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            object-fit: cover;
        }

        .profile-info h2 {
            margin: 0;
        }

        .profile-info p {
            margin: 5px 0;
            color: #666;
        }

        .stats {
            display: flex;
            gap: 20px;
            margin-top: 10px;
        }

        .stats div {
            font-weight: bold;
        }

        .stats a {
            color: inherit;
            text-decoration: none;
        }

        .stats a:hover {
            color: #0095f6;
        }

        .edit-section {
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #ddd;
        }

        .edit-section h3 {
            margin-bottom: 15px;
        }

        .edit-section input[type="file"] {
            margin-bottom: 10px;
        }

        .edit-section button {
            padding: 8px 20px;
            background: #0095f6;
            border: none;
            color: #fff;
            cursor: pointer;
            border-radius: 5px;
        }

        .create-post {
            background: #ffffff;
            padding: 15px;
            margin-top: 20px;
            border-radius: 5px;
            border: 1px solid #ddd;
        }

        .create-post textarea {
            width: 100%;
            min-height: 60px;
            resize: vertical;
            padding: 8px;
            border-radius: 4px;
            border: 1px solid #ccc;
            box-sizing: border-box;
            font-family: inherit;
        }

        .create-post input[type="file"] {
            margin-top: 8px;
        }

        .create-post button {
            margin-top: 10px;
            padding: 8px 15px;
            background: #0095f6;
            color: #fff;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }

        .follow-section {
            margin-top: 12px;
        }

        .follow-section form {
            display: inline;
        }

        .follow-section button {
            padding: 8px 20px;
            background: #0095f6;
            border: none;
            color: #fff;
            cursor: pointer;
            border-radius: 5px;
        }

        .follow-section .unfollow {
            background: #e9ecef;
            color: #111;
            border: 1px solid #ccc;
        }

        .back-link {
            display: inline-block;
            margin-top: 20px;
            color: #0095f6;
            text-decoration: none;
        }

        .posts-section {
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #ddd;
        }

        .posts-section h3 {
            margin: 0 0 15px;
        }

        .posts-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
        }

        .post-card {
            border: 1px solid #ddd;
            border-radius: 6px;
            padding: 12px;
            background: #fafafa;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .post-thumb {
            width: 100%;
            aspect-ratio: 1 / 1;
            background: #e9ecef;
            border-radius: 4px;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .post-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .post-title {
            font-weight: bold;
            margin-bottom: 8px;
            font-size: 14px;
            color: #333;
        }

        .post-summary-meta {
            font-size: 12px;
            color: #777;
            display: flex;
            gap: 6px;
            align-items: center;
            flex-wrap: wrap;
        }

        .no-user-posts {
            margin-top: 10px;
            font-size: 14px;
            color: #777;
        }
    </style>
</head>

<body>

<div class="container">

    <!-- PROFILE HEADER -->
    <div class="profile-header">
        <img src="/uploads/<%= profile && profile.profile_image ? profile.profile_image : 'default.png' %>" />

        <div class="profile-info">
            <h2>
                <%= (typeof profileUser !== 'undefined' && profileUser && profileUser.username) 
                    ? profileUser.username 
                    : user.username %>
            </h2>
            <p><%= profile.full_name %></p>

            <div class="stats">
                <div><%= profile.posts_count %> Posts</div>
                <div><a href="/profile/<%= profileUser.id %>/followers"><%= profile.followers_count %> Followers</a></div>
                <div><a href="/profile/<%= profileUser.id %>/following"><%= profile.following_count %> Following</a></div>
            </div>

            <% if (typeof isOwner !== 'undefined' && !isOwner) { %>
                <div class="follow-section">
                    <form action="/profile/<%= profileUser.id %>/follow" method="POST">
                        <% if (typeof isFollowing !== 'undefined' && isFollowing) { %>
                            <button type="submit" class="unfollow">Unfollow</button>
                        <% } else { %>
                            <button type="submit">Follow</button>
                        <% } %>
                    </form>
                </div>
            <% } %>
        </div>
    </div>

    <!-- EDIT PROFILE (only for own profile) -->
    <% if (typeof isOwner === 'undefined' || isOwner) { %>
    <div class="edit-section">
        <h3>Edit Profile</h3>

        <form action="/profile/upload" method="POST" enctype="multipart/form-data">
            <input type="file" name="profile_image" required />
            <br>
            <button type="submit">Change Profile Image</button>
        </form>
    </div>

    <!-- CREATE POST (only for own profile) -->
    <div class="create-post">
        <h3>Create Post</h3>
        <form action="/posts/create" method="POST" enctype="multipart/form-data">
            <textarea name="content" placeholder="What's on your mind?"></textarea>
            <input type="file" name="image" accept="image/*" />
            <br>
            <button type="submit">Post</button>
        </form>
    </div>
    <% } %>

    <!-- USER POSTS GRID -->
    <div class="posts-section">
        <h3>
            <% if (typeof isOwner === 'undefined' || isOwner) { %>
                Your Posts
            <% } else { %>
                <%= profileUser && profileUser.username ? profileUser.username : 'User' %>'s Posts
            <% } %>
        </h3>

        <% if (userPosts && userPosts.length > 0) { %>
            <div class="posts-grid">
                <% userPosts.forEach(function(post) { %>
                    <div class="post-card">
                        <div class="post-thumb">
                            <% if (post.image) { %>
                                <img src="/uploads/<%= post.image %>" alt="Post image" />
                            <% } else { %>
                                <span>No image</span>
                            <% } %>
                        </div>
                        <div class="post-title">
                            <% 
                                var heading = (post.content || "").trim();
                                if (!heading && post.image) {
                                    heading = "Photo post";
                                }
                                if (heading.length > 80) {
                                    heading = heading.substring(0, 80) + "...";
                                }
                            %>
                            <%= heading || "Untitled post" %>
                        </div>
                        <div class="post-summary-meta">
                            <span><%= post.likes_count || 0 %> Likes</span>
                            <span>•</span>
                            <span><%= post.comments_count || 0 %> Comments</span>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="no-user-posts">
                No posts yet.
            </div>
        <% } %>
    </div>

    <a class="back-link" href="/dashboard">← Back to Dashboard</a>

</div>

</body>
</html>
