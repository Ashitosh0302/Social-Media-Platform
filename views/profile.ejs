<!DOCTYPE html>
<html>
<head>
    <title>BirdSky · Profile</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #b7dff7 0%, #c6e9ff 40%, #d4f0ff 70%, #b3d5e7 100%);
            min-height: 100vh;
            position: relative;
        }

        /* Flying birds */
        .bird {
            position: fixed;
            color: #2f5570;
            font-size: 1.8rem;
            opacity: 0.2;
            z-index: 0;
            pointer-events: none;
            animation: fly 20s infinite linear;
        }

        @keyframes fly {
            0% { transform: translate(0, 0) rotate(0deg); }
            25% { transform: translate(40px, -10px) rotate(2deg); }
            50% { transform: translate(80px, 0) rotate(-1deg); }
            75% { transform: translate(40px, 8px) rotate(1deg); }
            100% { transform: translate(0, 0) rotate(0deg); }
        }

        @keyframes flyReverse {
            0% { transform: translate(0, 0) scaleX(-1) rotate(0deg); }
            25% { transform: translate(-40px, -8px) scaleX(-1) rotate(-2deg); }
            50% { transform: translate(-80px, 4px) scaleX(-1) rotate(1deg); }
            75% { transform: translate(-40px, 6px) scaleX(-1) rotate(-1deg); }
            100% { transform: translate(0, 0) scaleX(-1) rotate(0deg); }
        }

        .bird1 { top: 10%; left: -5%; animation-duration: 25s; }
        .bird2 { top: 25%; right: -5%; animation: flyReverse 28s infinite; }
        .bird3 { bottom: 15%; left: -8%; animation-duration: 32s; }
        .bird4 { bottom: 30%; right: -6%; animation: flyReverse 26s infinite; }

        /* Clouds */
        .cloud {
            position: fixed;
            background: rgba(255, 255, 255, 0.5);
            border-radius: 100px;
            filter: blur(40px);
            z-index: 0;
            pointer-events: none;
        }

        .cloud1 {
            width: 400px;
            height: 100px;
            top: 15%;
            right: -50px;
        }

        .cloud2 {
            width: 500px;
            height: 120px;
            bottom: 20%;
            left: -80px;
        }

        .page-wrapper {
            position: relative;
            z-index: 10;
            min-height: 100vh;
            padding: 30px 20px 40px;
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(12px);
            border-radius: 32px;
            padding: 40px;
            border: 1px solid rgba(255, 255, 255, 0.7);
            box-shadow: 0 15px 40px -10px rgba(0, 70, 100, 0.2);
            animation: fadeSlideUp 0.6s ease-out;
        }

        @keyframes fadeSlideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .profile-header {
            display: flex;
            align-items: center;
            gap: 40px;
            padding-bottom: 30px;
            border-bottom: 1px solid rgba(100, 180, 230, 0.3);
            margin-bottom: 30px;
        }

        .profile-avatar-wrap {
            position: relative;
            flex-shrink: 0;
        }

        .profile-header img {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid white;
            box-shadow: 0 8px 24px rgba(0, 60, 90, 0.2);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .profile-header img:hover {
            transform: scale(1.03);
            box-shadow: 0 12px 32px rgba(0, 60, 90, 0.25);
        }

        .profile-info {
            flex: 1;
            min-width: 0;
        }

        .profile-info h2 {
            margin: 0 0 6px;
            font-size: 1.8rem;
            color: #135e8a;
            font-weight: 700;
        }

        .profile-info .full-name {
            margin-bottom: 16px;
            font-size: 1rem;
            color: #2d6a8f;
        }

        .stats {
            display: flex;
            gap: 28px;
            margin-bottom: 18px;
        }

        .stats a, .stats .stat-block {
            text-decoration: none;
            color: #135e8a;
            font-weight: 600;
            font-size: 1rem;
            transition: color 0.2s, transform 0.2s;
        }

        .stats a:hover {
            color: #2c7da0;
            transform: translateY(-2px);
        }

        .stat-block {
            cursor: default;
        }

        .stat-num {
            font-weight: 700;
            margin-right: 4px;
        }

        .follow-section {
            margin-top: 4px;
        }

        .follow-section form {
            display: inline;
        }

        .follow-section button {
            padding: 10px 28px;
            border-radius: 40px;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.25s ease;
            border: 2px solid transparent;
        }

        .follow-section button:not(.unfollow) {
            background: linear-gradient(145deg, #2c7da0, #1e5f8a);
            color: white;
            border-color: rgba(255, 255, 255, 0.3);
            box-shadow: 0 4px 12px rgba(0, 70, 120, 0.25);
        }

        .follow-section button:not(.unfollow):hover {
            background: linear-gradient(145deg, #3597c0, #2473a0);
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(0, 70, 120, 0.3);
        }

        .follow-section .unfollow {
            background: rgba(255, 255, 255, 0.7);
            color: #135e8a;
            border-color: rgba(100, 180, 230, 0.5);
        }

        .follow-section .unfollow:hover {
            background: rgba(255, 255, 255, 0.9);
            transform: translateY(-2px);
        }

        .edit-section, .create-post {
            background: rgba(255, 255, 255, 0.5);
            backdrop-filter: blur(8px);
            padding: 24px;
            border-radius: 24px;
            border: 1px solid rgba(255, 255, 255, 0.7);
            margin-bottom: 24px;
            box-shadow: 0 8px 20px -8px rgba(0, 70, 100, 0.12);
            animation: fadeSlideUp 0.5s ease-out 0.1s both;
        }

        .edit-section h3, .create-post h3 {
            margin: 0 0 16px;
            font-size: 1.2rem;
            color: #135e8a;
        }

        .edit-section input[type="file"] {
            margin-bottom: 12px;
            padding: 8px;
            border-radius: 12px;
            border: 2px solid rgba(100, 180, 230, 0.5);
            background: rgba(255, 255, 255, 0.8);
        }

        .edit-section button, .create-post button {
            padding: 10px 24px;
            background: linear-gradient(145deg, #2c7da0, #1e5f8a);
            color: white;
            border: none;
            border-radius: 40px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.25s ease;
            box-shadow: 0 4px 12px rgba(0, 70, 120, 0.2);
        }

        .edit-section button:hover, .create-post button:hover {
            background: linear-gradient(145deg, #3597c0, #2473a0);
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(0, 70, 120, 0.3);
        }

        .create-post textarea {
            width: 100%;
            min-height: 80px;
            resize: vertical;
            padding: 14px 18px;
            border-radius: 16px;
            border: 2px solid rgba(100, 180, 230, 0.5);
            font-size: 0.95rem;
            font-family: inherit;
            background: rgba(255, 255, 255, 0.8);
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .create-post textarea:focus {
            outline: none;
            border-color: #2c7da0;
            box-shadow: 0 0 0 4px rgba(44, 125, 160, 0.15);
        }

        .create-post input[type="file"] {
            margin-top: 12px;
            padding: 8px;
            border-radius: 12px;
            border: 2px solid rgba(100, 180, 230, 0.5);
            background: rgba(255, 255, 255, 0.8);
        }

        .create-post button {
            margin-top: 14px;
        }

        .posts-section {
            margin-top: 30px;
            padding-top: 28px;
            border-top: 1px solid rgba(100, 180, 230, 0.3);
            animation: fadeSlideUp 0.5s ease-out 0.2s both;
        }

        .posts-section h3 {
            margin: 0 0 20px;
            font-size: 1.25rem;
            color: #135e8a;
        }

        .posts-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }

        .post-card {
            background: rgba(255, 255, 255, 0.5);
            backdrop-filter: blur(8px);
            border-radius: 20px;
            padding: 16px;
            border: 1px solid rgba(255, 255, 255, 0.7);
            box-shadow: 0 8px 20px -8px rgba(0, 70, 100, 0.12);
            display: flex;
            flex-direction: column;
            gap: 10px;
            transition: all 0.3s ease;
            animation: fadeSlideUp 0.4s ease-out both;
        }

        .post-card:nth-child(1) { animation-delay: 0.05s; }
        .post-card:nth-child(2) { animation-delay: 0.1s; }
        .post-card:nth-child(3) { animation-delay: 0.15s; }
        .post-card:nth-child(4) { animation-delay: 0.2s; }
        .post-card:nth-child(5) { animation-delay: 0.25s; }
        .post-card:nth-child(6) { animation-delay: 0.3s; }

        .post-card:hover {
            background: rgba(255, 255, 255, 0.7);
            transform: translateY(-4px);
            box-shadow: 0 12px 28px -8px rgba(0, 70, 100, 0.2);
        }

        .post-thumb {
            width: 100%;
            aspect-ratio: 1 / 1;
            background: rgba(176, 212, 240, 0.3);
            border-radius: 16px;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid white;
        }

        .post-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .post-thumb .no-img {
            color: #2d6a8f;
            font-size: 0.9rem;
        }

        .post-title {
            font-weight: 600;
            font-size: 0.95rem;
            color: #13506b;
            line-height: 1.4;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .post-summary-meta {
            font-size: 0.8rem;
            color: #2d6a8f;
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .no-user-posts {
            text-align: center;
            padding: 50px 20px;
            background: rgba(255, 255, 255, 0.4);
            border-radius: 24px;
            color: #135e8a;
            font-size: 1rem;
        }

        .bird-decoration {
            display: flex;
            justify-content: center;
            gap: 12px;
            margin-top: 20px;
            font-size: 1.2rem;
            opacity: 0.4;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-top: 28px;
            padding: 10px 24px;
            background: rgba(255, 255, 255, 0.6);
            color: #135e8a;
            text-decoration: none;
            border-radius: 40px;
            font-weight: 600;
            border: 2px solid rgba(100, 180, 230, 0.5);
            transition: all 0.25s ease;
            box-shadow: 0 4px 12px rgba(0, 70, 100, 0.1);
        }

        .back-link:hover {
            background: linear-gradient(145deg, #2c7da0, #1e5f8a);
            color: white;
            border-color: transparent;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(0, 70, 120, 0.25);
        }

        @media (max-width: 768px) {
            .profile-header {
                flex-direction: column;
                text-align: center;
            }

            .stats {
                justify-content: center;
            }

            .posts-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 500px) {
            .posts-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <div class="bird bird1">🕊️</div>
    <div class="bird bird2">🕊️</div>
    <div class="bird bird3">🕊️</div>
    <div class="bird bird4">🕊️</div>

    <div class="cloud cloud1"></div>
    <div class="cloud cloud2"></div>

    <div class="page-wrapper">
        <div class="container">
            <!-- PROFILE HEADER -->
            <div class="profile-header">
                <div class="profile-avatar-wrap">
                    <img src="<%= imageSrc(profile && profile.profile_image, '/images/default-avatar.svg') %>"
                         alt="Profile"
                         onerror="this.src='/images/default-avatar.svg'" />
                </div>

                <div class="profile-info">
                    <h2>
                        <%= (typeof profileUser !== 'undefined' && profileUser && profileUser.username)
                            ? profileUser.username
                            : user.username %>
                    </h2>
                    <p class="full-name"><%= profile.full_name || '—' %></p>

                    <div class="stats">
                        <span class="stat-block"><span class="stat-num"><%= profile.posts_count %></span> Posts</span>
                        <a href="/profile/<%= profileUser.id %>/followers"><span class="stat-num"><%= profile.followers_count %></span> Followers</a>
                        <a href="/profile/<%= profileUser.id %>/following"><span class="stat-num"><%= profile.following_count %></span> Following</a>
                    </div>

                    <% if (typeof isOwner !== 'undefined' && !isOwner) { %>
                        <div class="follow-section">
                            <form action="/profile/<%= profileUser.id %>/follow" method="POST">
                                <% if (typeof isFollowing !== 'undefined' && isFollowing) { %>
                                    <button type="submit" class="unfollow">Unfollow</button>
                                <% } else { %>
                                    <button type="submit">Follow</button>
                                <% } %>
                            </form>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- EDIT PROFILE (only for own profile) -->
            <% if (typeof isOwner === 'undefined' || isOwner) { %>
            <div class="edit-section">
                <h3>Edit Profile</h3>
                <form action="/profile/upload" method="POST" enctype="multipart/form-data">
                    <input type="file" name="profile_image" required accept="image/*" />
                    <br>
                    <button type="submit">Change Profile Image</button>
                </form>
            </div>

            <!-- CREATE POST (only for own profile) -->
            <div class="create-post">
                <h3>Create Post</h3>
                <form action="/posts/create" method="POST" enctype="multipart/form-data">
                    <textarea name="content" placeholder="What's on your mind?"></textarea>
                    <input type="file" name="image" accept="image/*" />
                    <br>
                    <button type="submit">Post</button>
                </form>
            </div>
            <% } %>

            <!-- USER POSTS GRID -->
            <div class="posts-section">
                <h3>
                    <% if (typeof isOwner === 'undefined' || isOwner) { %>
                        Your Posts
                    <% } else { %>
                        <%= profileUser && profileUser.username ? profileUser.username : 'User' %>'s Posts
                    <% } %>
                </h3>

                <% if (userPosts && userPosts.length > 0) { %>
                    <div class="posts-grid">
                        <% userPosts.forEach(function(post) { %>
                            <div class="post-card">
                                <div class="post-thumb">
                                    <% if (post.image) { %>
                                        <img src="<%= imageSrc(post.image) %>" alt="Post" loading="lazy" />
                                    <% } else { %>
                                        <span class="no-img">No image</span>
                                    <% } %>
                                </div>
                                <div class="post-title">
                                    <%
                                        var heading = (post.content || "").trim();
                                        if (!heading && post.image) heading = "Photo post";
                                        if (heading.length > 80) heading = heading.substring(0, 80) + "...";
                                    %>
                                    <%= heading || "Untitled post" %>
                                </div>
                                <div class="post-summary-meta">
                                    <span>❤️ <%= post.likes_count || 0 %> Likes</span>
                                    <span>•</span>
                                    <span>💬 <%= post.comments_count || 0 %> Comments</span>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="no-user-posts">
                        No posts yet.
                        <div class="bird-decoration">
                            <span>🕊️</span> <span>🪹</span> <span>🕊️</span>
                        </div>
                    </div>
                <% } %>
            </div>

            <a class="back-link" href="/dashboard">← Back to Dashboard</a>
        </div>
    </div>
</body>
</html>
