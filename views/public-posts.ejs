<!DOCTYPE html>
<html>
<head>
    <title>Public Posts</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f5f5f5;
        }
        .container {
            display: flex;
            min-height: 100vh;
        }
        .sidebar {
            width: 250px;
            background: #ffffff;
            padding: 20px;
            border-right: 1px solid #ddd;
        }
        .profile-box {
            text-align: center;
        }
        .profile-box img {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            object-fit: cover;
        }
        .profile-box h3 { margin: 10px 0 5px; }
        .profile-box a {
            display: inline-block;
            margin-top: 10px;
            padding: 8px 15px;
            background: #0095f6;
            color: #fff;
            text-decoration: none;
            border-radius: 5px;
        }
        .feed {
            flex: 1;
            padding: 30px;
        }
        .feed-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 10px;
        }
        .feed-header h2 { margin: 0; }
        .back-link {
            color: #0095f6;
            text-decoration: none;
        }
        .back-link:hover { text-decoration: underline; }
        .posts-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            max-width: 600px;
        }
        .post-card {
            background: #ffffff;
            border: 1px solid #ddd;
            border-radius: 6px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }
        .post-thumb {
            width: 100%;
            aspect-ratio: 1 / 1;
            background: #e9ecef;
            overflow: hidden;
        }
        .post-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .post-body {
            padding: 8px;
        }
        .post-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 4px;
        }
        .post-header h4 { margin: 0; font-size: 12px; }
        .post-meta { font-size: 10px; color: #777; }
        .post-content {
            font-size: 11px;
            color: #333;
            margin-bottom: 6px;
            line-height: 1.3;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .post-actions {
            margin-top: 4px;
        }
        .post-actions form { display: inline; }
        .post-actions button {
            background: none;
            border: none;
            color: #0095f6;
            cursor: pointer;
            padding: 0;
            font-size: 11px;
        }
        .post-stats {
            font-size: 10px;
            color: #777;
            margin-top: 2px;
        }
        .comments-preview {
            margin-top: 4px;
            font-size: 10px;
            color: #555;
            max-height: 36px;
            overflow-y: auto;
        }
        .comment-item {
            margin-bottom: 2px;
        }
        .add-comment {
            margin-top: 6px;
        }
        .add-comment input {
            width: 100%;
            padding: 4px 6px;
            border-radius: 4px;
            border: 1px solid #ccc;
            box-sizing: border-box;
            font-size: 11px;
        }
        .no-posts {
            text-align: center;
            color: #777;
            padding: 40px 20px;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="sidebar">
        <div class="profile-box">
            <img src="/uploads/<%= profile.profile_image ? profile.profile_image : 'default.png' %>" alt="Profile" />
            <h3><%= user.username %></h3>
            <a href="/profile">View Profile</a>
        </div>
    </div>

    <div class="feed">
        <div class="feed-header">
            <h2>Public Posts</h2>
            <a class="back-link" href="/dashboard">← Back to Dashboard</a>
        </div>

        <% if (!posts || posts.length === 0) { %>
            <div class="no-posts">
                <h3>No public posts yet</h3>
            </div>
        <% } else { %>
            <div class="posts-grid">
                <% posts.forEach(function(post) { %>
                    <div class="post-card">
                        <div class="post-thumb">
                            <% if (post.image) { %>
                                <img src="/uploads/<%= post.image %>" alt="Post" />
                            <% } else { %>
                                <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#999;">No image</div>
                            <% } %>
                        </div>
                        <div class="post-body">
                            <div class="post-header">
                                <h4><%= post.username %></h4>
                                <span class="post-meta"><%= new Date(post.created_at).toLocaleDateString() %></span>
                            </div>
                            <div class="post-content"><%= (post.content || '').trim() || '—' %></div>
                            <div class="post-actions">
                                <form action="/posts/<%= post.post_id %>/like" method="POST">
                                    <button type="submit">
                                        <% if (post.liked_by_me) { %>Unlike<% } else { %>Like<% } %>
                                        (<%= post.likes_count || 0 %>)
                                    </button>
                                </form>
                            </div>
                            <div class="post-stats"><%= (commentsByPost && commentsByPost[post.post_id] ? commentsByPost[post.post_id].length : 0) %> Comments</div>
                            <% const comments = (commentsByPost && commentsByPost[post.post_id]) || []; %>
                            <% if (comments.length > 0) { %>
                                <div class="comments-preview">
                                    <% comments.slice(0, 2).forEach(function(c) { %>
                                        <div class="comment-item"><strong><%= c.username %></strong> <%= c.comment_text %></div>
                                    <% }); %>
                                    <% if (comments.length > 2) { %><div class="comment-item">...</div><% } %>
                                </div>
                            <% } %>
                            <div class="add-comment">
                                <form action="/posts/<%= post.post_id %>/comment" method="POST">
                                    <input type="text" name="comment_text" placeholder="Add comment..." autocomplete="off" />
                                </form>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>
</div>

</body>
</html>
